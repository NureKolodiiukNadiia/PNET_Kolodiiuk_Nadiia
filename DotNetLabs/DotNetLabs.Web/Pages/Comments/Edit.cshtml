@page "{id:long}"
@model DotNetLabs.Web.Pages.Comments.EditModel
@{ ViewData["Title"] = "Edit Comment"; }
<h1>Edit Comment</h1>
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <input type="hidden" asp-for="CommentId" />
            <div class="form-group">
                <label asp-for="Text" class="control-label"></label>
                <input asp-for="Text" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="UserId" class="control-label"></label>
                <input asp-for="UserId" class="form-control" />
                <small class="form-text text-muted">Required to verify ownership</small>
            </div>
            <div class="form-group mt-2">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>
<div><a asp-page="./Index">Back to List</a></div>