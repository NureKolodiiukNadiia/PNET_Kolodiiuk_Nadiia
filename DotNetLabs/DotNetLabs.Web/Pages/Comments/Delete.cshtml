@page "{id:long}"
@model DotNetLabs.Web.Pages.Comments.DeleteModel
@{ ViewData["Title"] = "Delete Comment"; }
<h1>Delete Comment</h1>
<h3>Are you sure you want to delete this comment?</h3>
<div>
    <h4>Comment</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Text</dt>
        <dd class="col-sm-10">@Model.Text</dd>
    </dl>
    <form method="post">
        <input type="hidden" asp-for="CommentId" />
        <div class="form-group mb-2">
            <label asp-for="UserId" class="control-label">Your User ID (required to verify ownership)</label>
            <input asp-for="UserId" class="form-control" />
        </div>
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-page="./Index">Back to List</a>
    </form>
</div>