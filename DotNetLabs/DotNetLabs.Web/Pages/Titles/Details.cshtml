@page "{id:int}"
@model DotNetLabs.Web.Pages.Titles.DetailsModel
@{
    ViewData["Title"] = "Title Details";
}

<h1>Title Details</h1>
<div>
    <div><strong>Name:</strong> @Model.Title.Name</div>
    <div><strong>Average rating:</strong> @(Model.Title.AvgTmdbRating?.ToString("0.0") ?? "-")</div>
    <div><strong>Release date:</strong> @Model.Title.ReleaseDate?.ToString("yyyy-MM-dd")</div>
    <div><strong>Runtime:</strong> @Model.Title.Runtime</div>
    <div><strong>Is adult:</strong> @(Model.Title.IsAdult ? "Yes" : "No")</div>
    <div><strong>Overview:</strong> @Model.Title.Overview</div>
    <div><strong>Tagline:</strong> @Model.Title.Tagline</div>
    <div><strong>Director:</strong> @Model.Title.Director</div>
    <div><strong>Actors:</strong> @Model.Title.Actors</div>
    <div><strong>Production companies:</strong> @Model.Title.ProductionCompanies</div>
    <div><strong>Genres:</strong> @Model.Title.Genres</div>
    <div><strong>Keywords:</strong> @Model.Title.Keywords</div>
    <div><strong>Spoken languages:</strong> @Model.Title.SpokenLanguages</div>
    @if (!string.IsNullOrWhiteSpace(Model.Title.HomePage))
    {
        <div><strong>Home page:</strong> @Model.Title.HomePage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.Title.PosterUrl))
    {
        <div><strong>Poster URL:</strong> @Model.Title.PosterUrl</div>
    }
</div>

<div class="mt-3">
    <a asp-page="/Index" asp-route-page="@Model.Page" asp-route-pageSize="@Model.PageSize">Back to Titles</a>
</div>
