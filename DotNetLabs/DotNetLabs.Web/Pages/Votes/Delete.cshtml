@page
@model DotNetLabs.Web.Pages.Votes.DeleteModel
@{ ViewData["Title"] = "Delete Vote"; }
<h1>Delete Vote</h1>
<h3>Are you sure you want to delete this vote?</h3>
<div>
    <h4>Vote</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">TitleId</dt>
        <dd class="col-sm-10">@Model.TitleId</dd>
        <dt class="col-sm-2">UserId</dt>
        <dd class="col-sm-10">@Model.UserId</dd>
    </dl>
    <form method="post">
        <input type="hidden" asp-for="TitleId" />
        <input type="hidden" asp-for="UserId" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-page="./Index">Back to List</a>
    </form>
</div>