@page
@model IndexModel
@{
    ViewData["Title"] = "Titles";
}

<h1 class="mb-3">Titles</h1>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<p>
    <a class="btn btn-primary" asp-page="/Titles/Create">Create Title</a>
</p>

<div class="d-flex justify-content-between align-items-center mb-2">
    <span class="text-muted">Page @Model.PageNumber</span>
    <div>
        @if (Model.PageNumber > 1)
        {
            <a class="btn btn-sm btn-outline-secondary" asp-page="/Index" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-route-pageSize="@Model.PageSize">Previous</a>
        }
        <a class="btn btn-sm btn-outline-secondary" asp-page="/Index" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-route-pageSize="@Model.PageSize">Next</a>
    </div>
</div>

<table class="table table-striped">
    <thead>
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Avg rating</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @if (Model.Titles != null)
    {
        foreach (var item in Model.Titles)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@(item.AvgTmdbRating?.ToString("0.0") ?? "-")</td>
                <td>
                    <a asp-page="/Titles/Details" asp-route-id="@item.Id" asp-route-pageNumber="@Model.PageNumber" asp-route-pageSize="@Model.PageSize">Details</a>
                    |
                    <a asp-page="/Titles/Edit" asp-route-id="@item.Id" asp-route-pageNumber="@Model.PageNumber" asp-route-pageSize="@Model.PageSize">Edit</a>
                    |
                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline">
                        <input type="hidden" asp-for="PageNumber" />
                        <input type="hidden" asp-for="PageSize" />
                        <button type="submit" class="btn btn-link p-0 align-baseline">Delete</button>
                    </form>
                </td>
            </tr>
        }
    }
    </tbody>
</table>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
